/*
 * Nextflow Configuration File
 * Genome Primer Search Pipeline
 */

// Manifest
manifest {
    name = 'genome-primer-search'
    author = 'Justinas Kavoliūnas'
    description = 'Download reference genomes and search for primer binding sites'
    version = '0.2.0'
}

workDir = "_work"
outputDir = "_output"

// Default parameters
params {
    // Input files
    genomes = "${projectDir}/genomes/genomes.txt"
    primers = "${projectDir}/primers/primers.txt"

    // Output directory
    outdir = "_output"

    // Primersearch parameters
    mismatch = 0  // Mismatch percentage (0-100)

    // Filtering parameters
    max_amplicon_size = 10000  // Maximum amplicon size (bp) - filters circular artifacts
    min_amplicon_size = 50     // Minimum amplicon size (bp)

    // Thermodynamic analysis parameters (optional)
    enable_thermo_analysis = false  // Enable thermodynamic off-target analysis
    thermo_references = "${projectDir}/references/target_sequences.fasta"  // Reference target sequences
    thermo_master_mix = "DreamTaq"  // PCR master mix (DreamTaq, Q5_HighFidelity, Phusion_HF, etc.)
    thermo_annealing_temp = 60      // Annealing temperature (°C)
    thermo_delta_tm_high = 5        // ΔTm threshold for high amplification risk (°C)
    thermo_delta_tm_medium = 10     // ΔTm threshold for medium amplification risk (°C)

    // Performance parameters
    max_downloads = 12          // Maximum concurrent genome downloads
    max_searches = 8           // Maximum concurrent primersearch jobs

    // Help
    help = false
}

// Process execution configuration
process {
    // Error strategy
    errorStrategy = { task.attempt <= 2 ? 'retry' : 'ignore' }
    maxRetries = 2

    // Resource requirements per process
    withName: DOWNLOAD_GENOME {
        maxForks = params.max_downloads
        cpus = 1
        memory = '2 GB'
        time = '1h'
    }

    withName: EXTRACT_GENOME {
        cpus = 1
        memory = '1 GB'
        time = '30m'
    }

    withName: RUN_PRIMERSEARCH {
        maxForks = params.max_searches
        cpus = 1
        memory = '2 GB'
        time = '1h'
    }

    withName: FILTER_AMPLICONS {
        cpus = 1
        memory = '1 GB'
        time = '10m'
    }

    withName: GENERATE_REPORTS {
        cpus = 1
        memory = '2 GB'
        time = '10m'
    }

    withName: THERMODYNAMIC_ANALYSIS {
        cpus = 1
        memory = '2 GB'
        time = '30m'
    }

    withName: GENERATE_THERMO_REPORTS {
        cpus = 1
        memory = '2 GB'
        time = '10m'
    }
}

conda {
    enabled = true
}
